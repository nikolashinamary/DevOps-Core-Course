{
  "dashboard": {
    "id": null,
    "uid": "lab07logs",
    "title": "Lab07 Loki Dashboard",
    "tags": ["lab07", "loki", "observability"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Logs Table",
        "type": "logs",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 0},
        "datasource": {"type": "loki", "uid": "fffm1k60u3saob"},
        "targets": [
          {
            "refId": "A",
            "expr": "{app=~\"devops-.*\"}",
            "queryType": "range"
          }
        ],
        "options": {
          "showLabels": true,
          "showTime": true,
          "sortOrder": "Descending",
          "wrapLogMessage": true
        }
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 0},
        "datasource": {"type": "loki", "uid": "fffm1k60u3saob"},
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (app) (rate({app=~\"devops-.*\"}[1m]))",
            "queryType": "range"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Logs",
        "type": "logs",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 10},
        "datasource": {"type": "loki", "uid": "fffm1k60u3saob"},
        "targets": [
          {
            "refId": "A",
            "expr": "{app=~\"devops-.*\"} | json | level=\"ERROR\"",
            "queryType": "range"
          }
        ],
        "options": {
          "showLabels": true,
          "showTime": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 4,
        "title": "Log Level Distribution",
        "type": "stat",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 10},
        "datasource": {"type": "loki", "uid": "fffm1k60u3saob"},
        "targets": [
          {
            "refId": "A",
            "expr": "sum by (level) (count_over_time({app=~\"devops-.*\"} | json [5m]))",
            "queryType": "range"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value"
        }
      }
    ]
  },
  "overwrite": true
}
